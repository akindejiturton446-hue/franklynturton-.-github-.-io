<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Franklyn Turton | Data Analyst & AI Digital Asset Specialist</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --black: #080c10;
  --black-mid: #0f1620;
  --black-card: #141d27;
  --black-border: #1e2d3d;
  --blue: #1a6cf6;
  --blue-mid: #2979ff;
  --blue-light: #5b9bff;
  --blue-dim: rgba(26,108,246,0.12);
  --white: #f0f4f8;
  --white-dim: #a8b8cc;
  --white-faint: #4a5a6e;
}

* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
body {
  font-family: 'Inter', sans-serif;
  background: var(--black);
  color: var(--white);
  overflow-x: hidden;
}

/* ── NAV ── */
nav {
  position: fixed; top:0; width:100%; z-index:200;
  background: rgba(8,12,16,0.93);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--black-border);
  display: flex; justify-content: space-between; align-items: center;
  padding: 1.1rem 5rem;
}
.nav-logo {
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 700; font-size: 1.15rem;
  color: var(--white); letter-spacing: 1px;
}
.nav-logo span { color: var(--blue); }
.nav-links { display:flex; gap:2.5rem; list-style:none; }
.nav-links a {
  color: var(--white-dim);
  text-decoration: none;
  font-size: 0.8rem; font-weight: 500;
  letter-spacing: 1px; text-transform: uppercase;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--blue-light); }
.nav-cta {
  background: var(--blue);
  color: white !important;
  padding: 0.45rem 1.2rem;
  border-radius: 4px;
  font-weight: 600 !important;
}
.nav-cta:hover { background: var(--blue-mid) !important; color: white !important; }

/* ── HERO ── */
.hero {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  align-items: center;
  padding: 9rem 5rem 5rem;
  gap: 5rem;
  position: relative;
}
.hero::after {
  content:'';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(to right, transparent, var(--black-border), transparent);
}
.hero-glow {
  position: absolute;
  top: 10%; right: 5%;
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(26,108,246,0.08) 0%, transparent 65%);
  pointer-events: none;
}
.hero-available {
  display: inline-flex; align-items: center; gap: 0.5rem;
  background: rgba(26,108,246,0.1);
  border: 1px solid rgba(26,108,246,0.35);
  color: var(--blue-light);
  font-size: 0.75rem; font-weight: 600;
  letter-spacing: 1.5px; text-transform: uppercase;
  padding: 0.4rem 0.9rem; border-radius: 20px;
  margin-bottom: 1.5rem;
}
.hero-available::before {
  content:'';
  width:7px; height:7px;
  border-radius:50%;
  background: #22d38c;
  box-shadow: 0 0 8px #22d38c;
  animation: pulse 2s infinite;
}
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
.hero h1 {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 4rem; font-weight: 800;
  line-height: 1.08; color: var(--white);
  margin-bottom: 1rem;
}
.hero h1 .blue { color: var(--blue); }
.hero h1 .dim { color: var(--white-dim); font-weight: 400; }
.hero-role {
  font-size: 1rem; color: var(--blue-light);
  font-weight: 600; letter-spacing: 0.5px;
  margin-bottom: 1.5rem;
}
.hero-bio {
  font-size: 1rem; line-height: 1.85;
  color: var(--white-dim); max-width: 500px;
  margin-bottom: 2.5rem;
}
.hero-cta { display:flex; gap:1rem; flex-wrap:wrap; }
.btn-blue {
  background: var(--blue);
  color: white; padding: 0.85rem 2rem;
  border-radius: 5px; text-decoration: none;
  font-weight: 700; font-size: 0.9rem;
  transition: background 0.2s, transform 0.15s;
  letter-spacing: 0.3px;
}
.btn-blue:hover { background: var(--blue-mid); transform: translateY(-2px); }
.btn-ghost {
  border: 1.5px solid var(--black-border);
  color: var(--white-dim); padding: 0.85rem 2rem;
  border-radius: 5px; text-decoration: none;
  font-weight: 600; font-size: 0.9rem;
  transition: border-color 0.2s, color 0.2s, transform 0.15s;
}
.btn-ghost:hover { border-color: var(--blue); color: var(--blue-light); transform: translateY(-2px); }

/* HERO PHOTO */
.hero-photo-col { display:flex; justify-content:center; align-items:center; }
.photo-stack {
  position: relative;
  width: 320px;
}
.photo-stack::before {
  content: '';
  position: absolute;
  inset: -2px;
  border-radius: 8px;
  background: linear-gradient(135deg, var(--blue), transparent 60%);
  z-index: 0;
}
.photo-stack img {
  width: 320px; height: 370px;
  object-fit: cover; object-position: top;
  border-radius: 7px;
  position: relative; z-index: 1;
  display: block;
  filter: grayscale(15%) contrast(1.05);
}
.photo-tag {
  position: absolute;
  top: 20px; right: -50px;
  background: var(--black-card);
  border: 1px solid var(--black-border);
  border-radius: 8px;
  padding: 0.8rem 1rem;
  z-index: 3;
  font-size: 0.75rem;
  min-width: 140px;
}
.photo-tag .pt-label { color: var(--blue-light); font-weight: 700; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; }
.photo-tag .pt-val { color: var(--white); font-weight: 600; margin-top: 2px; }
.photo-tag2 {
  position: absolute;
  bottom: 20px; left: -50px;
  background: var(--black-card);
  border: 1px solid var(--black-border);
  border-radius: 8px;
  padding: 0.8rem 1rem;
  z-index: 3;
  font-size: 0.75rem;
  min-width: 140px;
}
.photo-tag2 .pt-label { color: #22d38c; font-weight: 700; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; }
.photo-tag2 .pt-val { color: var(--white); font-weight: 600; margin-top: 2px; }

/* ── STATS ── */
.stats-row {
  background: var(--black-mid);
  border-top: 1px solid var(--black-border);
  border-bottom: 1px solid var(--black-border);
  display: grid;
  grid-template-columns: repeat(4,1fr);
}
.stat {
  padding: 2rem;
  border-right: 1px solid var(--black-border);
  text-align: center;
}
.stat:last-child { border-right:none; }
.stat-n {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 2.6rem; font-weight: 800;
  color: var(--blue); line-height: 1;
}
.stat-l {
  font-size: 0.72rem; color: var(--white-faint);
  margin-top: 0.4rem; text-transform: uppercase; letter-spacing: 1.5px;
  font-weight: 600;
}

/* ── SECTIONS ── */
section { padding: 5.5rem 5rem; }
.s-eye {
  font-size: 0.7rem; font-weight: 700; letter-spacing: 3px;
  text-transform: uppercase; color: var(--blue);
  margin-bottom: 0.5rem;
}
.s-title {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 2.4rem; font-weight: 700; color: var(--white);
  margin-bottom: 2.8rem;
}
.s-title span { color: var(--blue); }

/* ── SKILLS ── */
#skills { background: var(--black-mid); }
.skills-grid {
  display: grid;
  grid-template-columns: repeat(3,1fr);
  gap: 1.2rem;
}
.sk-card {
  background: var(--black-card);
  border: 1px solid var(--black-border);
  border-radius: 8px; padding: 1.8rem;
  transition: border-color 0.2s, transform 0.2s;
}
.sk-card:hover { border-color: var(--blue); transform: translateY(-3px); }
.sk-icon { font-size: 1.6rem; margin-bottom: 1rem; }
.sk-name {
  font-size: 0.78rem; font-weight: 700;
  color: var(--white); text-transform: uppercase;
  letter-spacing: 1.5px; margin-bottom: 1rem;
}
.tags { display:flex; flex-wrap:wrap; gap:0.45rem; }
.tag {
  background: var(--blue-dim);
  border: 1px solid rgba(26,108,246,0.25);
  color: var(--blue-light);
  font-size: 0.72rem; padding: 0.28rem 0.65rem;
  border-radius: 3px; font-weight: 500;
}

/* ── PROJECTS ── */
#projects { background: var(--black); }
.proj-highlight {
  background: linear-gradient(135deg, rgba(26,108,246,0.08), rgba(26,108,246,0.03));
  border: 1px solid rgba(26,108,246,0.25);
  border-radius: 10px;
  padding: 2rem 2.5rem;
  margin-bottom: 2.5rem;
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 2rem; align-items: center;
}
.ph-icon {
  width: 70px; height: 70px;
  background: rgba(26,108,246,0.12);
  border: 1px solid rgba(26,108,246,0.3);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.8rem; flex-shrink: 0;
}
.ph-badge {
  display: inline-block;
  background: var(--blue);
  color: white; font-size: 0.65rem; font-weight: 700;
  letter-spacing: 1px; text-transform: uppercase;
  padding: 0.18rem 0.55rem; border-radius: 3px; margin-bottom: 0.5rem;
}
.ph-text h3 {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 1.3rem; color: var(--white); margin-bottom: 0.4rem;
}
.ph-text p { font-size: 0.88rem; color: var(--white-dim); line-height: 1.75; }

.proj-grid {
  display: grid;
  grid-template-columns: repeat(2,1fr);
  gap: 1.5rem;
}
.proj-card {
  background: var(--black-card);
  border: 1px solid var(--black-border);
  border-radius: 10px; overflow: hidden;
  transition: border-color 0.2s, transform 0.2s;
}
.proj-card:hover { border-color: var(--blue); transform: translateY(-4px); }
.proj-card.wide {
  grid-column: span 2;
  display: grid; grid-template-columns: 1fr 1fr;
}
.proj-visual {
  height: 200px;
  display: flex; align-items: center; justify-content: center;
  font-size: 4rem;
  position: relative; overflow: hidden;
}
.proj-visual.v1 { background: linear-gradient(135deg, #0a1628, #0d2545); }
.proj-visual.v2 { background: linear-gradient(135deg, #080c10, #111e2e); }
.proj-visual.v3 { background: linear-gradient(135deg, #0c1422, #0a1f35); }
.proj-visual.v1::after,
.proj-visual.v2::after,
.proj-visual.v3::after {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(circle at 30% 50%, rgba(26,108,246,0.15), transparent 60%);
}
.proj-card.wide .proj-visual { height: 100%; min-height: 260px; }
.proj-body { padding: 1.8rem; }
.proj-lbl {
  font-size: 0.68rem; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--blue-light); margin-bottom: 0.5rem;
}
.proj-title {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 1.15rem; color: var(--white);
  margin-bottom: 0.7rem; line-height: 1.35;
}
.proj-desc {
  font-size: 0.85rem; line-height: 1.75;
  color: var(--white-dim); margin-bottom: 1.2rem;
}
.proj-actions { display:flex; gap:0.7rem; }
.pa-live {
  background: var(--blue); color: white;
  padding: 0.4rem 1rem; border-radius: 4px;
  text-decoration: none; font-size: 0.76rem; font-weight: 700;
  transition: background 0.2s;
}
.pa-live:hover { background: var(--blue-mid); }
.pa-ghost {
  border: 1px solid var(--black-border); color: var(--white-faint);
  padding: 0.4rem 1rem; border-radius: 4px;
  text-decoration: none; font-size: 0.76rem; font-weight: 600;
  transition: border-color 0.2s, color 0.2s;
}
.pa-ghost:hover { border-color: var(--blue); color: var(--blue-light); }

/* ── EXPERIENCE ── */
#experience { background: var(--black-mid); }
.exp-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
}
.exp-card {
  background: var(--black-card);
  border: 1px solid var(--black-border);
  border-radius: 10px;
  padding: 2rem;
  position: relative;
  overflow: hidden;
}
.exp-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 3px; height: 100%;
  background: var(--blue);
}
.exp-card.current::before { background: linear-gradient(to bottom, var(--blue), #22d38c); }
.exp-period {
  font-size: 0.72rem; color: var(--blue-light);
  font-weight: 700; letter-spacing: 1px;
  text-transform: uppercase; margin-bottom: 0.4rem;
}
.exp-role {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 1.05rem; font-weight: 700;
  color: var(--white); margin-bottom: 0.2rem;
}
.exp-org {
  font-size: 0.82rem; color: var(--blue-light);
  font-weight: 600; margin-bottom: 1rem;
}
.exp-bullets { list-style: none; }
.exp-bullets li {
  font-size: 0.83rem; color: var(--white-dim);
  line-height: 1.75; padding-left: 1rem;
  position: relative; margin-bottom: 0.3rem;
}
.exp-bullets li::before {
  content: '›'; position: absolute; left: 0;
  color: var(--blue); font-weight: 700;
}
.exp-current-badge {
  position: absolute; top: 1rem; right: 1rem;
  background: rgba(34,211,140,0.12);
  border: 1px solid rgba(34,211,140,0.3);
  color: #22d38c; font-size: 0.65rem; font-weight: 700;
  letter-spacing: 1px; text-transform: uppercase;
  padding: 0.2rem 0.55rem; border-radius: 3px;
}

/* ── REVIEWS ── */
#reviews { background: var(--black); }
.rev-grid {
  display: grid;
  grid-template-columns: repeat(2,1fr);
  gap: 1.5rem;
}
.rev-card {
  background: var(--black-card);
  border: 1px solid var(--black-border);
  border-radius: 10px; padding: 2rem;
  transition: border-color 0.2s;
}
.rev-card:hover { border-color: rgba(26,108,246,0.4); }
.rev-stars { color: var(--blue-light); font-size: 0.9rem; margin-bottom: 0.8rem; }
.rev-q {
  font-size: 2.5rem; color: var(--blue);
  opacity: 0.25; line-height: 1; font-family: Georgia, serif;
}
.rev-text {
  font-size: 0.92rem; line-height: 1.85;
  color: var(--white-dim); font-style: italic;
  margin-bottom: 1.5rem;
}
.rev-person { display:flex; align-items:center; gap:0.9rem; }
.rev-avatar {
  width: 44px; height: 44px; border-radius: 50%;
  background: linear-gradient(135deg, var(--blue), #0a3a80);
  display: flex; align-items: center; justify-content: center;
  font-weight: 800; font-size: 0.85rem; color: white; flex-shrink: 0;
}
.rev-name { font-weight: 700; font-size: 0.88rem; color: var(--white); }
.rev-title { font-size: 0.75rem; color: var(--white-faint); margin-top: 2px; }

/* ── CONTACT ── */
#contact { background: var(--black-mid); text-align: center; }
.contact-inner { max-width: 580px; margin: 0 auto; }
.contact-inner p { color: var(--white-dim); font-size: 0.95rem; line-height: 1.8; margin-bottom: 2rem; }
.contact-grid {
  display: flex; flex-wrap: wrap; gap: 0.8rem; justify-content: center;
}
.c-link {
  display: flex; align-items: center; gap: 0.5rem;
  background: var(--black-card);
  border: 1px solid var(--black-border);
  color: var(--white-dim);
  padding: 0.75rem 1.4rem; border-radius: 6px;
  text-decoration: none; font-size: 0.82rem; font-weight: 600;
  transition: border-color 0.2s, color 0.2s, transform 0.15s;
}
.c-link:hover { border-color: var(--blue); color: var(--blue-light); transform: translateY(-2px); }

/* ── FOOTER ── */
footer {
  background: var(--black);
  border-top: 1px solid var(--black-border);
  padding: 1.8rem 5rem;
  display: flex; justify-content: space-between; align-items: center;
}
footer p { font-size: 0.78rem; color: var(--white-faint); }
.footer-brand {
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 700; color: var(--white);
}
.footer-brand span { color: var(--blue); }

/* ── MODALS ── */
.modal-overlay {
  display: none;
  position: fixed; inset: 0; z-index: 1000;
  background: rgba(0,0,0,0.85);
  backdrop-filter: blur(6px);
  overflow-y: auto;
  padding: 2rem 1rem;
  animation: fadeIn 0.2s ease;
}
@keyframes fadeIn { from{opacity:0} to{opacity:1} }
.modal-overlay.active { display: flex; align-items: flex-start; justify-content: center; }
.modal-box {
  background: var(--black-mid);
  border: 1px solid var(--black-border);
  border-radius: 14px;
  max-width: 860px; width: 100%;
  position: relative;
  animation: slideUp 0.3s ease;
  overflow: hidden;
}
@keyframes slideUp { from{transform:translateY(30px);opacity:0} to{transform:translateY(0);opacity:1} }
.modal-close {
  position: absolute; top: 1.2rem; right: 1.4rem;
  background: var(--black-card);
  border: 1px solid var(--black-border);
  color: var(--white-dim);
  width: 36px; height: 36px;
  border-radius: 50%; cursor: pointer;
  font-size: 1rem; z-index: 10;
  display: flex; align-items: center; justify-content: center;
  transition: border-color 0.2s, color 0.2s;
}
.modal-close:hover { border-color: var(--blue); color: var(--white); }
.modal-header {
  background: linear-gradient(135deg, rgba(26,108,246,0.1), rgba(26,108,246,0.03));
  border-bottom: 1px solid var(--black-border);
  padding: 2.5rem 2.5rem 2rem;
}
.modal-label {
  font-size: 0.68rem; font-weight: 700; letter-spacing: 2px;
  text-transform: uppercase; color: var(--blue-light); margin-bottom: 0.6rem;
}
.modal-title {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 1.7rem; font-weight: 700; color: var(--white);
  line-height: 1.25; margin-bottom: 1rem;
}
.modal-meta { display:flex; flex-wrap:wrap; gap:0.5rem; }
.mm-item {
  background: var(--blue-dim);
  border: 1px solid rgba(26,108,246,0.2);
  color: var(--blue-light);
  font-size: 0.75rem; font-weight: 600;
  padding: 0.3rem 0.8rem; border-radius: 20px;
}
.modal-story { padding: 2.5rem; }
.story-section { margin-bottom: 2rem; }
.story-h {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 1.1rem; font-weight: 700; color: var(--white);
  margin-bottom: 0.7rem;
  padding-left: 0.9rem;
  border-left: 3px solid var(--blue);
}
.story-p {
  font-size: 0.92rem; line-height: 1.85;
  color: var(--white-dim); margin-bottom: 0.8rem;
}
/* Pipeline visual */
.story-visual {
  background: var(--black-card);
  border: 1px solid var(--black-border);
  border-radius: 10px;
  padding: 1.5rem;
  margin-bottom: 2rem;
}
.sv-label {
  font-size: 0.7rem; font-weight: 700; letter-spacing: 2px;
  text-transform: uppercase; color: var(--blue);
  margin-bottom: 1.2rem;
}
.sv-caption {
  font-size: 0.78rem; color: var(--white-faint);
  margin-top: 0.8rem; font-style: italic;
}
.pipeline-steps {
  display: flex; align-items: flex-start; gap: 0.5rem;
  flex-wrap: nowrap; overflow-x: auto;
}
.ps-step {
  background: rgba(26,108,246,0.07);
  border: 1px solid rgba(26,108,246,0.2);
  border-radius: 8px; padding: 1rem;
  flex: 1; min-width: 120px;
  text-align: center;
}
.ps-icon { font-size: 1.5rem; margin-bottom: 0.4rem; }
.ps-title {
  font-size: 0.75rem; font-weight: 700;
  color: var(--white); text-transform: uppercase;
  letter-spacing: 0.5px; margin-bottom: 0.4rem;
}
.ps-desc { font-size: 0.72rem; color: var(--white-faint); line-height: 1.5; }
.ps-arrow {
  color: var(--blue); font-size: 1.2rem;
  padding-top: 1.5rem; flex-shrink: 0;
}
/* QA grid */
.qa-grid {
  display: grid; grid-template-columns: repeat(2,1fr); gap: 0.8rem;
}
.qa-item {
  display: flex; align-items: flex-start; gap: 0.7rem;
  background: rgba(34,211,140,0.05);
  border: 1px solid rgba(34,211,140,0.15);
  border-radius: 6px; padding: 0.9rem;
}
.qa-icon {
  color: #22d38c; font-size: 1rem;
  font-weight: 700; flex-shrink: 0; margin-top: 1px;
}
.qa-title { font-size: 0.82rem; font-weight: 700; color: var(--white); margin-bottom: 2px; }
.qa-desc { font-size: 0.75rem; color: var(--white-faint); line-height: 1.4; }
/* Outcomes */
.modal-outcomes {
  display: grid; grid-template-columns: repeat(4,1fr);
  gap: 1rem; margin-top: 2rem;
  padding-top: 2rem;
  border-top: 1px solid var(--black-border);
}
.mo-item { text-align: center; }
.mo-n {
  display: block;
  font-family: 'Space Grotesk', sans-serif;
  font-size: 1.8rem; font-weight: 800; color: var(--blue);
  line-height: 1;
}
.mo-l {
  font-size: 0.72rem; color: var(--white-faint);
  margin-top: 0.3rem; text-transform: uppercase; letter-spacing: 0.5px;
}
/* Before/After */
